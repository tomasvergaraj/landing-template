---
import { waLink } from '../config';
import WhatsAppIcon from './WhatsAppIcon.astro';
---

<a
  href={waLink()}
  class="wa-float"
  target="_blank"
  rel="noopener"
  aria-label="Escríbenos por WhatsApp"
>
  <span class="wa-float__ring" aria-hidden="true"></span>
  <span class="wa-float__btn">
    <WhatsAppIcon size={30} />
  </span>
  <span class="wa-float__tip" aria-hidden="true">¿Hablamos?</span>
</a>

<style>
  .wa-float {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
  }

  /* Anillo pulsante detrás del botón */
  .wa-float__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #25d366;
    z-index: 0;
    animation: wa-pulse 2.4s var(--ease-out) infinite;
  }

  /* Botón verde redondo */
  .wa-float__btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    box-shadow:
      0 8px 20px rgba(37, 211, 102, 0.42),
      0 16px 40px rgba(25, 23, 28, 0.16);
    transition: transform var(--t-base), box-shadow var(--t-base);
    will-change: transform;
  }
  .wa-float__btn :global(svg) { width: 30px; height: 30px; }

  .wa-float:hover .wa-float__btn,
  .wa-float:focus-visible .wa-float__btn {
    transform: scale(1.08);
    box-shadow:
      0 12px 28px rgba(37, 211, 102, 0.5),
      0 24px 56px rgba(25, 23, 28, 0.2);
  }
  .wa-float:active .wa-float__btn { transform: scale(1.02); }

  /* Tooltip (solo escritorio, aparece al hover) */
  .wa-float__tip {
    position: absolute;
    right: calc(100% + 14px);
    top: 50%;
    transform: translateY(-50%) translateX(8px);
    padding: 9px 15px;
    border-radius: var(--r-pill);
    background: var(--ink);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    white-space: nowrap;
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--t-base), transform var(--t-base);
  }
  /* Pequeña flecha del tooltip */
  .wa-float__tip::after {
    content: '';
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: var(--ink);
  }
  .wa-float:hover .wa-float__tip,
  .wa-float:focus-visible .wa-float__tip {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  @keyframes wa-pulse {
    0%   { transform: scale(1);   opacity: 0.65; }
    70%  { transform: scale(1.7); opacity: 0; }
    100% { transform: scale(1.7); opacity: 0; }
  }

  /* Móvil: algo más pequeño y pegado a la esquina; sin tooltip */
  @media (max-width: 620px) {
    .wa-float {
      right: 18px;
      bottom: 18px;
      width: 54px;
      height: 54px;
    }
    .wa-float__btn { width: 54px; height: 54px; }
    .wa-float__btn :global(svg) { width: 27px; height: 27px; }
    .wa-float__tip { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float__ring { animation: none; opacity: 0; }
  }
</style>
