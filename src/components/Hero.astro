---
import { Icon } from 'astro-icon/components';
import { HERO, waLink } from '../config';
import WhatsAppIcon from './WhatsAppIcon.astro';
import Warp from './Warp.astro';
---

<section id="top" class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <Warp variant="light" class="hero__warp" />

  <!-- Tarjetas flotantes decorativas (kinetic playground) -->
  <span class="hero__deco hero__deco--a float" aria-hidden="true">
    <Icon name="lucide:sparkles" />
  </span>
  <span class="hero__deco hero__deco--b float2" aria-hidden="true">
    <Icon name="lucide:zap" />
  </span>
  <span class="hero__deco hero__deco--c float3" aria-hidden="true">
    <Icon name="lucide:heart-handshake" />
  </span>
  <span class="hero__deco hero__deco--d float2" aria-hidden="true">
    <Icon name="lucide:shield-check" />
  </span>

  <div class="container hero__inner">
    <span class="eyebrow reveal">{HERO.badge}</span>

    <h1 class="display hero__title reveal" style="--reveal-delay:.06s">
      {HERO.titlePre}{' '}
      <span class="mark">{HERO.titleMark}</span>{' '}
      {HERO.titlePost}
    </h1>

    <p class="lead hero__lead reveal" style="--reveal-delay:.12s">{HERO.subtitle}</p>

    <div class="hero__cta reveal" style="--reveal-delay:.18s">
      <a href={waLink()} class="btn btn--primary btn--lg" target="_blank" rel="noopener">
        <WhatsAppIcon size={20} /> {HERO.ctaPrimary}
      </a>
      <a href="#servicios" class="btn btn--ghost btn--lg">
        {HERO.ctaSecondary}
        <Icon name="lucide:arrow-down" />
      </a>
    </div>

    <div class="hero__stats reveal" style="--reveal-delay:.26s">
      {HERO.stats.map((s, i) => (
        <div class={`hero__stat hero__stat--${i}`}>
          <span class="hero__stat-num" data-countup>{s.number}</span>
          <span class="hero__stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(140px, 20vh, 210px);
    padding-bottom: clamp(60px, 8vw, 110px);
    text-align: center;
    overflow: clip;
  }

  .hero__glow {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(560px 380px at 22% 12%, rgba(122, 64, 237, 0.16), transparent 70%),
      radial-gradient(520px 420px at 82% 8%, rgba(0, 178, 255, 0.14), transparent 70%),
      radial-gradient(700px 500px at 50% 120%, rgba(245, 255, 99, 0.14), transparent 70%);
  }

  /* Warp de hiperespacio sutil (GT-Planar), enmascarado para no
     estorbar la lectura del titular central. */
  .hero__warp {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.55;
    -webkit-mask-image: radial-gradient(58% 58% at 50% 46%, transparent 34%, #000 76%);
    mask-image: radial-gradient(58% 58% at 50% 46%, transparent 34%, #000 76%);
  }

  .hero__inner { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; }

  .hero__title {
    max-width: 15ch;
    margin-top: 26px;
  }

  .hero__lead {
    max-width: 56ch;
    margin-top: 26px;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 38px;
  }

  /* Stats como tarjetas acolchadas ligeramente rotadas */
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    justify-content: center;
    margin-top: 56px;
  }
  .hero__stat {
    background: var(--white);
    border-radius: var(--r-xl);
    padding: 22px 30px;
    min-width: 168px;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(255,255,255,0.6);
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: transform var(--t-base), box-shadow var(--t-base);
  }
  .hero__stat:hover { transform: translateY(-6px) rotate(0deg) !important; box-shadow: var(--shadow-lg); }
  .hero__stat--0 { rotate: -2.5deg; }
  .hero__stat--1 { rotate: 1.5deg; translate: 0 -8px; }
  .hero__stat--2 { rotate: 3deg; }
  .hero__stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.4rem;
    letter-spacing: -0.04em;
    color: var(--violet);
    line-height: 1;
  }
  .hero__stat--1 .hero__stat-num { color: var(--blue); }
  .hero__stat--2 .hero__stat-num { color: var(--ink); }
  .hero__stat-label {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--slate);
    letter-spacing: -0.01em;
  }

  /* Decoración flotante */
  .hero__deco {
    position: absolute;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-md);
  }
  .hero__deco :global(svg) { width: 30px; height: 30px; }
  .hero__deco--a { top: 20%; left: 8%; width: 74px; height: 74px; background: var(--violet); color: #fff; rotate: -10deg; }
  .hero__deco--b { top: 16%; right: 9%; width: 66px; height: 66px; background: var(--volt); color: var(--ink); rotate: 8deg; }
  .hero__deco--c { top: 54%; left: 12%; width: 64px; height: 64px; background: var(--blue); color: #fff; rotate: 6deg; border-radius: 50%; }
  .hero__deco--d { top: 58%; right: 11%; width: 70px; height: 70px; background: var(--white); color: var(--violet); rotate: -6deg; }

  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }
  .float  { animation: floaty 6s var(--ease-out) infinite; }
  .float2 { animation: floaty 7.5s var(--ease-out) -2s infinite; }
  .float3 { animation: floaty 5.5s var(--ease-out) -1s infinite; }

  @media (max-width: 1050px) { .hero__deco { display: none; } }
  @media (max-width: 620px) {
    .hero__stat { min-width: 0; flex: 1 1 44%; padding: 18px; }
    .hero__stat-num { font-size: 1.9rem; }
    .hero__cta .btn { width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .float, .float2, .float3 { animation: none; }
  }
</style>
