---
import { LOGOS } from '../config';

// Duplicamos los items para un bucle continuo y sin costuras.
const track = [...LOGOS.items, ...LOGOS.items];
---

<section id="logos" class="logos" aria-label={LOGOS.title}>
  <div class="container logos__inner">
    <p class="mono logos__title reveal"><span class="logos__slash">//</span> {LOGOS.title}</p>

    <div class="logos__viewport reveal" style="--reveal-delay:.08s">
      <ul class="logos__track" aria-hidden="false">
        {track.map((name, i) => (
          <li class="logos__item" aria-hidden={i >= LOGOS.items.length ? 'true' : 'false'}>
            <span class="logos__glyph" aria-hidden="true"></span>
            <span class="logos__name">{name}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .logos {
    /* Banda esbelta y aireada, no una tarjeta pesada */
    padding-block: clamp(32px, 5vw, 56px);
  }

  .logos__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(18px, 2.5vw, 26px);
  }

  .logos__title {
    font-size: 0.74rem;
    text-align: center;
    max-width: 46ch;
  }
  .logos__slash { color: var(--violet); }

  /* Ventana con desvanecido en ambos bordes */
  .logos__viewport {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 12%,
      #000 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 12%,
      #000 88%,
      transparent 100%
    );
  }

  /* Pista flexible que se desplaza (marquesina infinita) */
  .logos__track {
    display: flex;
    align-items: center;
    gap: clamp(38px, 5vw, 68px);
    width: max-content;
    padding-block: 4px;
    animation: marquee-x 34s linear infinite;
    will-change: transform;
  }
  .logos__viewport:hover .logos__track {
    animation-play-state: paused;
  }

  .logos__item {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    flex: 0 0 auto;
    color: var(--slate);
    transition: color var(--t-fast);
  }
  .logos__item:hover { color: var(--ink); }

  /* Glifo (cuadrado redondeado violeta) antes del nombre */
  .logos__glyph {
    width: 14px;
    height: 14px;
    border-radius: 5px;
    background: var(--violet);
    box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.35);
    rotate: -8deg;
    flex: 0 0 auto;
  }

  /* Wordmark monocromo */
  .logos__name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    white-space: nowrap;
  }

  @media (max-width: 620px) {
    .logos__name { font-size: 1.12rem; }
    .logos__track { gap: clamp(30px, 8vw, 44px); }
  }

  /* Movimiento reducido: sin desplazamiento, se ajusta y centra */
  @media (prefers-reduced-motion: reduce) {
    .logos__track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
      gap: 16px 34px;
    }
    /* Evita nombres duplicados cuando no hay bucle */
    .logos__item[aria-hidden='true'] { display: none; }
    .logos__viewport {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
