---
import { PROCESS } from '../config';

// Colores de badge alternados con la paleta de marca
// (volt usa texto oscuro para contraste)
const badgeVariants = ['violet', 'blue', 'volt', 'violet', 'blue'];
---

<section id="proceso" class="section proceso" aria-labelledby="proceso-title">
  <div class="container">
    <div class="section-head section-head--center reveal">
      <span class="eyebrow eyebrow--blue">{PROCESS.eyebrow}</span>
      <h2 class="h2 proceso__title" id="proceso-title">{PROCESS.title}</h2>
      <p class="lead proceso__lead">{PROCESS.subtitle}</p>
    </div>

    <ol class="proceso__steps">
      {PROCESS.steps.map((step, i) => (
        <li class="proceso__step reveal" style={`--reveal-delay:${(0.08 * i).toFixed(2)}s`}>
          <span
            class={`proceso__badge proceso__badge--${badgeVariants[i % badgeVariants.length]}`}
          >
            {step.num}
          </span>
          <div class="proceso__body">
            <h3 class="h3 proceso__step-title">{step.title}</h3>
            <p class="text-soft proceso__desc">{step.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  /* Espaciado interno de la cabecera centrada */
  .proceso :global(.eyebrow) { margin-bottom: 18px; }
  .proceso__title { margin-bottom: 16px; }
  .proceso__lead { max-width: 58ch; margin-inline: auto; }

  /* ── Fila de pasos ──────────────────────────────────────────── */
  .proceso__steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 22px;
    margin-top: clamp(28px, 4.5vw, 48px);
  }

  /* Riel punteado detrás de los badges (horizontal en desktop) */
  .proceso__steps::before {
    content: '';
    position: absolute;
    top: 28px;               /* centro del badge (56px / 2) */
    left: 10%;
    right: 10%;
    height: 3px;
    background-image: linear-gradient(90deg, var(--lavender) 0 58%, transparent 0);
    background-size: 16px 100%;
    z-index: 0;
  }

  .proceso__step {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 18px;
  }

  /* Badge del número (cuadrado redondeado, 56px) */
  .proceso__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--r-md);
    flex-shrink: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: -0.02em;
    color: var(--white);
    background: var(--violet);
    /* Halo del color de fondo para "cortar" el riel en cada badge */
    box-shadow: 0 0 0 7px var(--bg), var(--shadow-sm);
    rotate: -4deg;
    transition: transform var(--t-base), rotate var(--t-base), box-shadow var(--t-base);
  }
  .proceso__step:nth-child(even) .proceso__badge { rotate: 4deg; }

  .proceso__badge--violet {
    background: var(--violet);
    color: var(--white);
    box-shadow: 0 0 0 7px var(--bg), var(--shadow-violet);
  }
  .proceso__badge--blue { background: var(--blue); color: var(--ink); }
  .proceso__badge--volt { background: var(--volt); color: var(--ink); }

  /* Realce lúdico al pasar el cursor */
  .proceso__step:hover .proceso__badge {
    transform: translateY(-6px);
    rotate: 0deg;
    box-shadow: 0 0 0 7px var(--bg), var(--shadow-md);
  }
  .proceso__step:hover .proceso__badge--violet {
    box-shadow: 0 0 0 7px var(--bg), var(--shadow-violet);
  }

  .proceso__step-title { margin-bottom: 8px; }
  .proceso__desc {
    font-size: 0.96rem;
    line-height: 1.5;
    max-width: 24ch;
    margin-inline: auto;
  }

  /* ── Tablet ─────────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .proceso__steps { gap: 16px; }
    .proceso__steps::before { left: 10%; right: 10%; }
    .proceso__badge { width: 52px; height: 52px; font-size: 1.25rem; }
    .proceso__steps::before { top: 26px; }
    .proceso__desc { font-size: 0.9rem; }
  }

  /* ── Móvil: apilado vertical con riel a la izquierda ────────── */
  @media (max-width: 620px) {
    .proceso__steps {
      grid-template-columns: 1fr;
      gap: 26px;
      max-width: 440px;
      margin-inline: auto;
    }
    .proceso__steps::before {
      top: 28px;
      bottom: 28px;
      left: 26px;            /* centro del badge (52px / 2) */
      right: auto;
      width: 3px;
      height: auto;
      background-image: linear-gradient(180deg, var(--lavender) 0 58%, transparent 0);
      background-size: 100% 16px;
    }
    .proceso__step {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 18px;
    }
    .proceso__badge { width: 52px; height: 52px; font-size: 1.25rem; }
    .proceso__step-title { margin-top: 6px; }
    .proceso__desc { max-width: none; margin-inline: 0; }
  }

  /* ── Accesibilidad: reducir movimiento ──────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .proceso__badge,
    .proceso__step:hover .proceso__badge { transform: none; rotate: 0deg; }
  }
</style>
